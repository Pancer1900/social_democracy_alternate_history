####################### adding advisors

@add_advisors
title: Add advisors
choose-if: n_advisors < 5
unavailable-subtitle: Maximum of 5 advisors.
go-to: advisor_menu

@advisor_menu
title: Add other advisors.
tags: center_advisor, left_advisor, reformist_advisor, labor_advisor, nonfactional_advisor, revolutionaries_advisor, agrarnians_advisor 
frequency: 1


- @centrist: Add Centrists
- @left: Add Leftists
- @revolutionaries: Add Revolutionaries
- @agrarnians: Add Agrarnians
- @reformist: Add Reformists
- @labor: Add Labor
- @nonfactional: Add non-factional advisors
- @rm_main: Remove advisors instead.
- @remove_none: Stop changing advisors.

@centrist
view-if: n_advisors < 5

