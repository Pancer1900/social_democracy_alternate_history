#revolutionaries

@add_ferenn
title: Anna Ferenn
subtitle: Anna Ferenn is an economist and one of our chief Marxist theoreticians. {!<br><br>!}[? if difficulty < 0 : Actions - Against Right and Left, Defending Toleration, Fiscal Policy, Economic Democracy ?]
is-card: true
card-image: img/portraits/HilferdingRudolf.jpg
tags: revolutionaries_advisor
view-if: ferenn_advisor = 0 and n_advisors < 5 and revolutionaries_split = 0
on-arrival: ferenn_advisor = 1; n_advisors += 1; revolutionaries_strength += 5
go-to: advisor_menu

