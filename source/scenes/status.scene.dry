Child Labour: [? if child_lab = 0 : <span style="color: #ce2e25;">Legal</span> ?][? if child_lab = 1 : <span style="color: #ce5a25;">Regulated</span> ?][? if child_lab = 2 : <span style="color: #ceb025;">Heavily Restricted</span> ?][? if child_lab >= 3 : <span style="color: #9ece25;">Illegal</span> ?]

